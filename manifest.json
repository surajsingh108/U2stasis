{
  "manifest_version": 3,
  "name": "Neuro-Cinematic Tracker",
  "version": "3.1",
  "description": "Predicts YouTube viewing retention live using CLIP embeddings — runs entirely in the browser, no server needed.",
  "permissions": ["storage", "alarms"],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "web_accessible_resources": [
    {
      "resources": ["transformers.min.js"],
      "matches": ["https://www.youtube.com/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/watch*"],
      "js": ["content.js"]
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Neuro-Cinematic Tracker"
  }
}
